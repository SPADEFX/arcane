{
  "name": "@uilibrary/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./dist/style.css",
    "./components/*": "./src/components/*.tsx",
    "./sections/*": "./src/sections/*.tsx"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-dropdown-menu": "^2",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1",
    "@radix-ui/react-visually-hidden": "^1",
    "@uilibrary/hooks": "workspace:*",
    "@uilibrary/motion": "workspace:*",
    "@uilibrary/tokens": "workspace:*",
    "@uilibrary/utils": "workspace:*",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "motion": "^12"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5.7",
    "vite": "^6"
  }
}
